/* FAQ — Usage */
"faq.usage.goalstatuscolors.q" = "¿Qué significan los colores del estado del objetivo?";
"faq.usage.goalstatuscolors.a" = "El color junto al estado de tu objetivo es una señal rápida de progreso basada en tu valor más reciente. El verde significa que vas por buen camino, el amarillo que sigues cerca pero conviene vigilarlo, y el rojo que el último resultado se aleja más claramente de la meta. El objetivo es ayudarte a analizar el progreso rápidamente, no a juzgar tu salud.";
"faq.usage.photocomparison.q" = "¿Cómo funciona la comparación de fotos?";
"faq.usage.photocomparison.a" = "Abre la pestaña Fotos y toca Comparar. Selecciona una foto de Antes y otra de Después, luego elige el modo Lado a lado o Deslizador para ver la diferencia. Desliza para cambiar de vista.";
