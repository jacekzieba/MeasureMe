"BMI is within the typical range for this age." = "BMI mieści się w typowym zakresie dla tego wieku.";
"Your BMI is within the healthy range." = "Twoje BMI mieści się w zdrowym zakresie.";
"BMI is above the typical range for this age." = "BMI jest powyżej typowego zakresu dla tego wieku.";
"Your BMI indicates overweight." = "Twoje BMI wskazuje na nadwagę.";
"BMI is significantly above the typical range for this age." = "BMI jest znacząco powyżej typowego zakresu dla tego wieku.";
