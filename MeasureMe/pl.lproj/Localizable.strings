/* FAQ — Użytkowanie */
"faq.usage.goalstatuscolors.q" = "Co oznaczają kolory statusu celu?";
"faq.usage.goalstatuscolors.a" = "Kolor obok statusu celu to szybki sygnał postępu oparty na Twoim ostatnim wyniku. Zielony oznacza, że jesteś na dobrej drodze, żółty że nadal jesteś blisko celu, ale warto to obserwować, a czerwony że ostatni wynik wyraźniej oddala się od celu. To ma pomagać szybko ocenić postęp, a nie oceniać Twoje zdrowie.";
"faq.usage.photocomparison.q" = "Jak działa porównanie zdjęć?";
"faq.usage.photocomparison.a" = "Przejdź do zakładki Zdjęcia i dotknij Porównaj. Wybierz zdjęcie Przed i Po, a następnie wybierz tryb obok siebie lub suwaka. Przesuń, aby przełączyć widoki.";
"faq.usage.ghostoverlay.q" = "Jak używać nakładki duchów?";
"faq.usage.ghostoverlay.a" = "Podczas porównania zdjęć dotknij ikony nakładki, aby przełączyć się w tryb Duch. Przeciągnij, aby zmienić pozycję, szczypnij, aby skalować, i użyj suwaka, aby dostosować przezroczystość.";
"faq.usage.sharetransformation.q" = "Jak udostępnić swoją transformację?";
"faq.usage.sharetransformation.a" = "Podczas porównywania dwóch zdjęć dotknij Udostępnij transformację, aby wygenerować kartę przed/po. Możesz udostępnić ją w mediach społecznościowych lub zapisać do biblioteki zdjęć.";

/* FAQ — Premium */
"faq.premium.widgets.q" = "Czym są widżety?";
"faq.premium.widgets.a" = "Widżety wyświetlają najnowszą wartość metryki bezpośrednio na ekranie głównym lub ekranie blokady. Przejdź do Ustawienia → Widżety, aby skonfigurować, którą metrykę wyświetla każdy widżet.";
"faq.premium.aiinsights.q" = "Jak działają Spostrzeżenia AI?";
"faq.premium.aiinsights.a" = "Spostrzeżenia AI używają Apple Intelligence do analizy ostatniego trendu i generowania krótkiego, spersonalizowanego podsumowania. Działa na urządzeniu, wymaga obsługiwanego urządzenia z włączonym Apple Intelligence i odświeża się raz dziennie lub po zapisaniu nowej wartości.";
"faq.premium.icloudbackup.q" = "Co obejmuje kopia zapasowa iCloud?";
"faq.premium.icloudbackup.a" = "Kopia zapasowa iCloud przechowuje wszystkie Twoje pomiary, cele i zdjęcia w zaszyfrowanej formie na Twoim osobistym koncie iCloud. Działa automatycznie, gdy aplikacja jest w tle, i można ją przywrócić z Ustawienia → Dane → Przywróć z kopii zapasowej.";
"faq.premium.goalprediction.q" = "Jak działa Prognoza celu?";
"faq.premium.goalprediction.a" = "Po ustawieniu celu Prognoza celu wykorzystuje podwójne wygładzanie wykładnicze do analizy ostatniego trendu i oszacowania, kiedy osiągniesz cel. Wymaga co najmniej 7 pomiarów w ciągu 7 dni. Jeśli trend oddala się od celu lub jest płaski, zamiast daty wyświetlany jest pomocny komunikat.";

