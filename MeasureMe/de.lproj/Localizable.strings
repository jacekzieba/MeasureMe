/* FAQ — Usage */
"faq.usage.goalstatuscolors.q" = "Was bedeuten die Farben des Zielstatus?";
"faq.usage.goalstatuscolors.a" = "Die Farbe neben Ihrem Zielstatus ist ein schnelles Fortschrittssignal basierend auf Ihrem neuesten Wert. Grün bedeutet, dass Sie auf dem richtigen Weg sind, Gelb bedeutet, dass Sie immer noch nah dran sind, es aber sehenswert ist, und Rot bedeutet, dass das aktuelle Ergebnis deutlicher vom Ziel entfernt ist. Es soll Ihnen dabei helfen, den Fortschritt schnell zu erfassen, und nicht, Ihren Gesundheitszustand zu beurteilen.";
"faq.usage.photocomparison.q" = "Wie funktioniert der Fotovergleich?";
"faq.usage.photocomparison.a" = "Öffnen Sie die Registerkarte „Fotos“ und tippen Sie auf „Vergleichen“. Wählen Sie ein Vorher-Nachher-Foto aus und wählen Sie dann den Modus „Nebeneinander“ oder „Schieberegler“, um den Unterschied zu sehen. Wischen Sie, um die Ansicht zu wechseln.";
