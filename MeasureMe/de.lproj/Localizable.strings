"faq.usage.ghostoverlay.q" = "Wie nutze ich die Überlagerung?";
"faq.usage.ghostoverlay.a" = "Tippe im Fotovergleich auf das Overlay-Symbol, um in den Überlagerungsmodus zu wechseln. Ziehe, um die Überlagerung neu zu positionieren, ziehe sie auseinander oder zusammen, um sie zu skalieren, und nutze den Schieberegler, um die Deckkraft anzupassen.";
"faq.usage.sharetransformation.q" = "Wie teile ich meine Transformation?";
"faq.usage.sharetransformation.a" = "Tippe beim Vergleichen zweier Fotos auf „Transformation teilen“, um eine Vorher/Nachher-Karte zu erstellen. Du kannst es dann in sozialen Medien teilen oder in deiner Fotobibliothek speichern.";

/* FAQ — Premium */
"faq.premium.widgets.q" = "Was sind Widgets?";
"faq.premium.widgets.a" = "Widgets zeigen deinen neuesten Messwert direkt auf dem Startbildschirm oder Sperrbildschirm an. Geh zu Einstellungen → Widgets, um zu konfigurieren, welche Metrik jedes Widget anzeigt.";
"faq.premium.aiinsights.q" = "Wie funktionieren KI-Einblicke?";
"faq.premium.aiinsights.a" = "Die KI-Einblicke nutzen Apple Intelligence, um deinen aktuellen Trend zu analysieren und eine kurze, personalisierte Zusammenfassung zu erstellen. Die Verarbeitung läuft auf dem Gerät, erfordert ein unterstütztes Gerät mit aktivierter Apple Intelligence und wird einmal täglich oder beim Eintragen eines neuen Werts aktualisiert.";
"faq.premium.icloudbackup.q" = "Was beinhaltet das iCloud-Backup?";
"faq.premium.icloudbackup.a" = "Das iCloud-Backup speichert alle deine Messungen, Ziele und Fotos verschlüsselt in deinem persönlichen iCloud-Konto. Es läuft automatisch im Hintergrund und kann über Einstellungen → Daten → Aus Backup wiederherstellen wieder eingespielt werden.";
"faq.premium.goalprediction.q" = "Wie funktioniert die Zielprognose?";
"faq.premium.goalprediction.a" = "Wenn du ein Ziel festlegst, nutzt die Zielprognose doppelte exponentielle Glättung, um deinen Trend zu analysieren und abzuschätzen, wann du dein Ziel erreichst. Dafür brauchst du mindestens 7 Messungen innerhalb von 7 Tagen. Wenn sich dein Trend vom Ziel entfernt oder flach bleibt, zeigen wir statt eines Datums eine hilfreiche Erklärung.";

