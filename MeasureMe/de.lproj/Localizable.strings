"faq.usage.ghostoverlay.q" = "Wie verwende ich Ghost-Overlay?";
"faq.usage.ghostoverlay.a" = "Tippen Sie im Fotovergleich auf das Overlay-Symbol, um in den Ghost-Modus zu wechseln. Ziehen Sie, um die Überlagerung neu zu positionieren, ziehen Sie sie zusammen, um sie zu skalieren, und verwenden Sie den Schieberegler, um die Deckkraft anzupassen.";
"faq.usage.sharetransformation.q" = "Wie teile ich meine Transformation?";
"faq.usage.sharetransformation.a" = "Tippen Sie beim Vergleichen zweier Fotos auf „Transformation teilen“, um eine Vorher/Nachher-Karte zu erstellen. Sie können es dann in sozialen Medien teilen oder in Ihrer Fotobibliothek speichern.";

/* FAQ — Premium */
"faq.premium.widgets.q" = "Was sind Widgets?";
"faq.premium.widgets.a" = "Widgets zeigen Ihren neuesten Messwert direkt auf dem Startbildschirm oder Sperrbildschirm an. Gehen Sie zu Einstellungen → Widgets, um zu konfigurieren, welche Metrik jedes Widget anzeigt.";
"faq.premium.aiinsights.q" = "Wie funktionieren KI-Einblicke?";
"faq.premium.aiinsights.a" = "Die KI-Einblicke nutzen Apple Intelligence, um Ihren aktuellen Trend zu analysieren und eine kurze, personalisierte Zusammenfassung zu erstellen. Sie laufen auf dem Gerät, erfordern ein unterstütztes Gerät mit aktivierter Apple Intelligence und werden einmal täglich oder beim Protokollieren eines neuen Werts aktualisiert.";
"faq.premium.icloudbackup.q" = "Was beinhaltet das iCloud-Backup?";
"faq.premium.icloudbackup.a" = "iCloud Backup speichert alle Ihre Messungen, Ziele und Fotos in verschlüsselter Form in Ihrem persönlichen iCloud-Konto. Es wird automatisch ausgeführt, wenn die App im Hintergrund läuft, und kann über Einstellungen → Daten → Aus Backup wiederherstellen wiederhergestellt werden.";
"faq.premium.goalprediction.q" = "Wie funktioniert die Zielprognose?";
"faq.premium.goalprediction.a" = "Wenn Sie ein Ziel festlegen, verwendet die Zielprognose die doppelte exponentielle Glättung, um Ihren aktuellen Trend zu analysieren und abzuschätzen, wann Sie Ihr Ziel erreichen werden. Es sind mindestens 7 Messungen innerhalb von 7 Tagen erforderlich. Wenn sich Ihr Trend vom Ziel entfernt oder flach ist, wird anstelle eines Datums eine hilfreiche Meldung angezeigt.";

