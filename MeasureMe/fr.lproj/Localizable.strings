"faq.usage.ghostoverlay.q" = "Comment utiliser la superposition fantôme ?";
"faq.usage.ghostoverlay.a" = "Dans la comparaison de photos, appuyez sur l'icône de superposition pour passer en mode Ghost. Faites glisser pour repositionner la superposition, pincez pour la redimensionner et utilisez le curseur pour ajuster l'opacité.";
"faq.usage.sharetransformation.q" = "Comment partager ma transformation ?";
"faq.usage.sharetransformation.a" = "Tout en comparant deux photos, appuyez sur Partager la transformation pour générer une carte avant/après. Vous pouvez ensuite le partager sur les réseaux sociaux ou l'enregistrer dans votre bibliothèque Photos.";

/* FAQ — Premium */
"faq.premium.widgets.q" = "Que sont les widgets ?";
"faq.premium.widgets.a" = "Les widgets affichent votre dernière valeur directement sur l’écran d’accueil ou l’écran verrouillé. Accédez à Réglages → Widgets pour choisir la mesure affichée par chaque widget.";
"faq.premium.aiinsights.q" = "Comment fonctionnent les analyses IA ?";
"faq.premium.aiinsights.a" = "Les analyses IA utilisent Apple Intelligence pour interpréter votre tendance récente et générer un résumé court et personnalisé. Elles s’exécutent sur l’appareil, nécessitent un appareil compatible avec Apple Intelligence activé, et se mettent à jour une fois par jour ou lorsqu’une nouvelle valeur est enregistrée.";
"faq.premium.icloudbackup.q" = "Que comprend la sauvegarde iCloud ?";
"faq.premium.icloudbackup.a" = "La sauvegarde iCloud stocke toutes vos mesures, objectifs et photos sous forme cryptée dans votre compte personnel iCloud. Il s'exécute automatiquement lorsque l'application est en arrière-plan et peut être restauré à partir de Paramètres → Données → Restaurer à partir d'une sauvegarde.";
"faq.premium.goalprediction.q" = "Comment fonctionne la prédiction d'objectifs ?";
"faq.premium.goalprediction.a" = "Lorsque vous définissez un objectif, Goal Prediction utilise le double lissage exponentiel pour analyser votre tendance récente et estimer le moment où vous atteindrez votre objectif. Il nécessite au moins 7 mesures sur 7 jours. Si votre tendance s'éloigne de l'objectif ou est stable, un message utile s'affiche à la place d'une date.";

